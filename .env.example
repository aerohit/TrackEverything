# Template for the app's environment variables — copy to `.env.local` for local dev.
# NEVER put real values here; this file IS committed. Real values live in:
#   - local dev:        .env.local        (gitignored)
#   - laptop-run ops:   secrets/<env>.env (gitignored; used by the Makefile)
#   - runtime:          Deno Deploy env vars, per environment (marked secret)
#   - CI / migrations:  GitHub Environment secrets (test | preprod | prod)
# See docs/DEPLOYMENT.md.

# Postgres connection string. Local = throwaway Postgres; deployed = Supabase pooled URL.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5500/te

# Shared bearer token the PWA + API require on every /api request (any long random string).
INGEST_TOKEN=replace-with-a-long-random-string

# Optional — enables Claude vision (label scan), meal recognition, and Ask LLM.
# Leave empty to run without them (those endpoints return 503).
ANTHROPIC_API_KEY=

# Optional — override the default Claude model id.
CLAUDE_MODEL=

# Environment name, surfaced on /health and the PWA's non-prod banner.
# One of: dev | test | preprod | prod
APP_ENV=dev
