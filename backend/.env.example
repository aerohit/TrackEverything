# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Anthropic API key (https://console.anthropic.com/) — used by the live test
# suite and the hello function. Not required for the default `deno task test`.
ANTHROPIC_API_KEY=

# Claude model id. Defaults to claude-opus-4-8 if unset.
CLAUDE_MODEL=claude-opus-4-8

# Postgres connection string. When set, the DB integration test runs against it;
# when unset, that test is skipped so the suite still passes locally.
# Local Supabase default looks like:
#   postgres://postgres:postgres@localhost:54322/postgres
DATABASE_URL=

# Shared secret that capture clients (the Shortcut) must present to POST events.
# Generate a long random string, e.g. `openssl rand -hex 32`. If unset, the
# events endpoint accepts unauthenticated writes — fine for local dev, never deploy
# it that way.
INGEST_TOKEN=

