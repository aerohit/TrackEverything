{
  "tasks": {
    "test": "deno test --allow-env --allow-net --allow-read tests/unit/ tests/integration/",
    "test:unit": "deno test --allow-env tests/unit/",
    "test:live": "deno test --allow-env --allow-net tests/live/",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "check": "deno check **/*.ts",
    "migrate": "deno run --allow-env --allow-net --allow-read scripts/migrate.ts",
    "seed": "deno run --allow-env --allow-net --allow-read scripts/insert_sample_event.ts",
    "templates:seed": "deno run --allow-env --allow-net --allow-read scripts/seed_templates.ts",
    "serve:hello": "deno run --allow-env --allow-net functions/hello/index.ts",
    "serve:events": "deno run --allow-env --allow-net functions/events/index.ts",
    "serve:capture": "deno run --allow-env --allow-net functions/capture/index.ts",
    "serve:templates": "deno run --allow-env --allow-net functions/templates/index.ts",
    "serve:quicklog": "deno run --allow-env --allow-net functions/quicklog/index.ts",
    "serve:products": "deno run --allow-env --allow-net functions/products/index.ts",
    "serve:ingredient-scan": "deno run --allow-env --allow-net functions/ingredient_scan/index.ts",
    "serve:checkin": "deno run --allow-env --allow-net functions/checkin/index.ts",
    "serve:ask": "deno run --allow-env --allow-net functions/ask/index.ts",
    "start": "deno run --allow-env --allow-net main.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.8"
  },
  "fmt": {
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
